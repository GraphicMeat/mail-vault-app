{
  "name": "mailvault",
  "version": "2.6.0",
  "description": "A reactive email client with local storage capabilities",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "client": "vite",
    "postinstall": "cd website/api && npm install",
    "build": "node scripts/write-env.cjs && vite build",
    "preview": "vite preview",
    "tauri": "tauri",
    "tauri:dev": "tauri dev",
    "dev:full": "./scripts/dev.sh",
    "tauri:build": "npm run build:daemon && tauri build",
    "tauri:build:debug": "npm run build:daemon && tauri build --debug",
    "build:daemon": "node scripts/build-daemon.js",
    "tauri:icon": "tauri icon",
    "build:release": "./scripts/build-developer-id.sh",
    "build:appstore": "./scripts/build-appstore.sh",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "cd src-tauri && cargo build --features webdriver && cd .. && wdio run wdio.conf.js",
    "test:e2e:ui": "wdio run wdio.conf.js --suite ui",
    "test:e2e:connected": "wdio run wdio.conf.js --suite connected",
    "test:e2e:backup": "wdio run wdio.conf.js --suite backup",
    "test:e2e:migration": "wdio run wdio.conf.js --suite migration",
    "test:e2e:visual": "wdio run wdio.conf.js --suite visual",
    "test:e2e:all": "wdio run wdio.conf.js"
  },
  "dependencies": {
    "@tanstack/react-virtual": "^3.13.18",
    "@tauri-apps/plugin-http": "^2.5.7",
    "@tiptap/extension-link": "^3.21.0",
    "@tiptap/extension-placeholder": "^3.21.0",
    "@tiptap/extension-underline": "^3.21.0",
    "@tiptap/pm": "^3.21.0",
    "@tiptap/react": "^3.21.0",
    "@tiptap/starter-kit": "^3.21.0",
    "darkreader": "^4.9.120",
    "date-fns": "^2.30.0",
    "framer-motion": "^10.16.16",
    "lucide-react": "^0.294.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "tauri-plugin-sparkle-updater-api": "^0.2.2",
    "uuid": "^9.0.1",
    "zustand": "^4.4.7"
  },
  "devDependencies": {
    "@tauri-apps/api": "^2",
    "@tauri-apps/cli": "^2",
    "@tauri-apps/plugin-dialog": "^2",
    "@tauri-apps/plugin-fs": "^2",
    "@tauri-apps/plugin-process": "^2",
    "@tauri-apps/plugin-shell": "^2",
    "@tauri-apps/plugin-updater": "^2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^18.2.43",
    "@types/react-dom": "^18.2.17",
    "@vitejs/plugin-react": "^5.1.4",
    "@wdio/cli": "^9.24.0",
    "@wdio/local-runner": "^9.24.0",
    "@wdio/mocha-framework": "^9.24.0",
    "@wdio/spec-reporter": "^9.24.0",
    "@wdio/visual-service": "^9.2.0",
    "autoprefixer": "^10.4.16",
    "jsdom": "^29.0.0",
    "postcss": "^8.4.32",
    "tailwindcss": "^3.3.6",
    "vite": "^6.4.1",
    "vitest": "^4.0.18",
    "webdriverio": "^9.24.0"
  },
  "overrides": {
    "serialize-javascript": "^7.0.5"
  }
}
