<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <!-- App Sandbox — helper is sandboxed like the main app.
         Aligned for both Developer ID and Mac App Store builds. -->
    <key>com.apple.security.app-sandbox</key>
    <true/>

    <!-- Network access for IMAP/SMTP sync -->
    <key>com.apple.security.network.client</key>
    <true/>

    <!-- Keychain access (shared with main app) -->
    <key>com.apple.security.keychain-access-groups</key>
    <array>
        <string>$(AppIdentifierPrefix)com.mailvault.app</string>
        <string>$(AppIdentifierPrefix)group.com.mailvault</string>
    </array>

    <!-- App Group for IPC socket, token, and shared state -->
    <key>com.apple.security.application-groups</key>
    <array>
        <string>group.com.mailvault</string>
    </array>
</dict>
</plist>
