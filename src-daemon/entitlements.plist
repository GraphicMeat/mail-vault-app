<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <!-- NO app-sandbox here.  A standalone binary (no Info.plist / bundle
         structure) cannot opt into its own sandbox — libsystem_secinit
         aborts at launch.  Instead the daemon inherits the parent app's
         sandbox when spawned as a Tauri sidecar (on-demand mode).
         To sandbox the daemon independently it must first be packaged as
         an app bundle with Info.plist, then registered via SMAppService. -->

    <!-- Network access for IMAP/SMTP sync -->
    <key>com.apple.security.network.client</key>
    <true/>

    <!-- Keychain access (shared with main app) -->
    <key>com.apple.security.keychain-access-groups</key>
    <array>
        <string>$(AppIdentifierPrefix)com.mailvault.app</string>
        <string>$(AppIdentifierPrefix)group.com.mailvault</string>
    </array>

    <!-- App Group for IPC socket, token, and shared state -->
    <key>com.apple.security.application-groups</key>
    <array>
        <string>group.com.mailvault</string>
    </array>
</dict>
</plist>
