# Server
PORT=3001

# CORS - set to your website domain in production
CORS_ORIGIN=https://mailvaultapp.com

# Security
IP_SALT=change-this-to-a-random-string
ADMIN_KEY=change-this-to-a-secure-admin-key

# SMTP - for contact form email notifications
SMTP_HOST=smtp.hostinger.com
SMTP_PORT=465
SMTP_USER=hello@mailvaultapp.com
SMTP_PASS=your-email-password

# Email to receive contact form notifications
NOTIFY_EMAIL=hello@forceunwrap.com

# Database (optional - defaults to ./data.json)
# DB_PATH=/path/to/data.json

# Stripe Billing (required for premium features)
# Get test keys from: https://dashboard.stripe.com/test/apikeys
STRIPE_SECRET_KEY=sk_test_...
# EUR-based prices with currency_options for USD/GBP + Stripe Adaptive Pricing
STRIPE_PRICE_MONTHLY_EUR=price_...
STRIPE_PRICE_YEARLY_EUR=price_...
# Legacy USD-only fallback (used if _EUR vars not set)
# STRIPE_PRICE_MONTHLY=price_...
# STRIPE_PRICE_YEARLY=price_...
# Webhook secret from: stripe listen --forward-to localhost:3001/api/billing/webhook
STRIPE_WEBHOOK_SECRET=whsec_...

# Billing redirect URLs (defaults to mailvaultapp.com)
# BILLING_SUCCESS_URL=http://localhost:5173/billing-success.html
# BILLING_CANCEL_URL=http://localhost:5173/billing-cancel.html
